---
// lib/site/src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en" class="">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <script is:inline>
      // Standalone dark-mode bootstrap. Default is light; dark applies only when
      // explicitly opted into via localStorage. nixos.org's own bootstrap takes
      // precedence when these components are consumed inside the homepage build,
      // because <html class="dark"> is already set by then.
      (() => {
        if (localStorage.getItem('theme') === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-primary-white text-primary-black-15 dark:bg-primary-black-15 dark:text-primary-white-85">
    <main class="mx-auto max-w-[1168px] px-4 py-12">
      <slot />
    </main>
  </body>
</html>
