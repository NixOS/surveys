---
// lib/site/src/components/PlotRow.astro
import { marked } from 'marked';

interface Props {
  row: {
    id: string;
    title: string;
    commentary: string;
    chart: {
      option: Record<string, unknown>;
      height?: number;
    };
  };
  variant?: 'neobrutalist' | 'homepage' | 'bare';
}

const { row, variant = 'neobrutalist' } = Astro.props;

const cardClass: Record<NonNullable<Props['variant']>, string> = {
  neobrutalist: 'border-2 border-primary-black shadow-[3px_3px_0_theme(colors.primary-black.DEFAULT)] dark:border-primary-white dark:shadow-[3px_3px_0_theme(colors.primary-white.DEFAULT)]',
  homepage: 'rounded-lg shadow-md bg-primary-white dark:bg-primary-black-15',
  bare: '',
};

const height = row.chart.height ?? 320;
---
<div class="plot-row grid md:grid-cols-[280px_1fr] gap-5 mb-5">
  <article class={`p-5 ${cardClass[variant]}`}>
    <h3 id={row.id} class="font-bold mb-2">{row.title}</h3>
    <div set:html={marked.parse(row.commentary)} />
  </article>
  <article
    class={`p-5 ${cardClass[variant]}`}
    data-echarts-option
    style={`height: ${height}px`}
  >
    <script type="application/json" set:html={JSON.stringify(row.chart.option)} />
    <div class="echarts-chart w-full h-full"></div>
  </article>
</div>
