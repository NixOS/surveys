---
// lib/site/src/components/PlotRow.astro
import { marked } from 'marked';

interface Props {
  row: {
    id: string;
    title: string;
    question: string;
    commentary: string;
    charts: Array<{
      option: Record<string, unknown>;
      height?: number;
      caption?: string;
    }>;
    wide?: boolean;
  };
  variant?: 'neobrutalist' | 'homepage' | 'bare';
}

const { row, variant = 'neobrutalist' } = Astro.props;

const rowClass: Record<NonNullable<Props['variant']>, string> = {
  neobrutalist: 'rounded-xl overflow-hidden border-2 border-secondary-afghani-blue dark:border-secondary-afghani-blue-75 bg-primary-white dark:bg-primary-black-15 shadow-sm hover:shadow-md transition-shadow duration-200',
  homepage: 'rounded-xl overflow-hidden border-2 border-secondary-afghani-blue dark:border-secondary-afghani-blue-75 bg-primary-white dark:bg-primary-black-15 shadow-sm hover:shadow-md transition-shadow duration-200',
  bare: '',
};

---
<div class={`plot-row mb-5 break-inside-avoid ${row.wide ? '[column-span:all] mt-5' : ''} ${rowClass[variant]}`}>
  <article class="p-5">
    <h3 id={row.id} class="text-lg font-bold mb-1 font-heading text-secondary-afghani-blue dark:text-secondary-afghani-blue-75">
      <a href={`#${row.id}`} class="heading-link group inline-flex items-center gap-2 no-underline">
        <span>{row.title}</span>
        <svg class="link-icon h-4 w-4 shrink-0 opacity-0 group-hover:opacity-50 transition" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
        </svg>
      </a>
    </h3>
    <p class="mb-3 text-sm italic text-primary-black-65 dark:text-primary-white-45">{row.question}</p>
    <div class="max-w-prose" set:html={marked.parse(row.commentary)} />
  </article>
  {row.charts.map((chart, i) => (
    <article class={`p-5 ${i > 0 ? 'pt-0' : ''}`} data-echarts-option>
      <div class={i > 0 ? 'border-t border-secondary-afghani-blue/20 dark:border-secondary-afghani-blue-75/20 pt-5' : ''}>
        {chart.caption && <div class="max-w-prose mb-4 text-sm" set:html={marked.parse(chart.caption)} />}
        <script type="application/json" set:html={JSON.stringify(chart.option)} />
        <div class="echarts-chart w-full" style={`height: ${chart.height ?? 320}px`}></div>
      </div>
    </article>
  ))}
</div>
