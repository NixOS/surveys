---
interface Props {
  sections: { id: string; heading: string }[];
}
const { sections } = Astro.props;
---
<nav aria-label="Contents" class="mt-12 mb-4 rounded-xl border-2 border-secondary-afghani-blue dark:border-secondary-afghani-blue-75 p-5">
  <h2 class="mb-3 text-sm uppercase tracking-widest font-semibold text-primary-black-65 dark:text-primary-white-65">Contents</h2>
  <ul class="flex flex-wrap gap-x-6 gap-y-2 list-none p-0">
    {sections.map(s => (
      <li>
        <a href={`#${s.id}`} class="text-secondary-afghani-blue dark:text-secondary-afghani-blue-75 hover:underline">{s.heading}</a>
      </li>
    ))}
  </ul>
</nav>
