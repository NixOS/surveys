# Raw survey response CSVs contain PII (individual answers, free-text fields,
# granular metadata) and must NEVER be committed. Synthetic test fixtures under
# overlays/python-packages/nixos-survey-lib/tests/fixtures/ are re-included via
# a local negation rule in that directory.
*.csv

# Python bytecode caches
__pycache__/
*.pyc

# Nix build outputs
result
result-*

# Override a common user-global `result*` ignore so the Astro content
# collection directory is tracked. The per-year JSON inside it is still
# a build artifact (copied from a Nix derivation) and stays ignored.
!lib/site/src/content/results/
lib/site/src/content/results/results-*.json
